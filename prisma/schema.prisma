generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  candidate
  campaign_manager
  co_chair
  field_organizer
  canvasser
  volunteer_coordinator
  finance_lead
}

enum SupportLevel {
  strong_yes
  soft_yes
  undecided
  soft_no
  strong_no
  not_home
}

enum CanvassOutcome {
  contacted
  not_home
  refused
  moved
  unavailable
  deceased
}

enum OutreachChannel {
  door_knock
  phone_call
  email
  text_message
  in_person
  other
}

// ─── Campaign ─────────────────────────────────────────────────────────────────

model Campaign {
  id           String   @id @default(cuid())
  name         String
  ballotName   String?
  officeSought String?
  description  String?
  municipality String?
  wards        String[]
  city         String
  province     String   @default("ON")
  year         Int
  electionDate DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   CampaignMembership[]
  people        Person[]
  households    Household[]
  addresses     Address[]
  canvassLists  CanvassList[]
  outreachLogs  OutreachLog[]
  donors           Donor[]
  volunteerRecords VolunteerRecord[]
  volunteerShifts  VolunteerShift[]
  auditLogs        AuditLog[]
  tasks            Task[]

  @@map("campaigns")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phoneHome    String?
  phoneMobile  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships          CampaignMembership[]
  canvassAssignments   CanvassAssignment[]
  canvassListEntries   CanvassListEntry[]
  notes                Note[]
  tasksAssigned        Task[]
  outreachLogs         OutreachLog[]
  auditLogs            AuditLog[]
  donorsCreated        Donor[]

  @@map("users")
}

// ─── Campaign Membership ──────────────────────────────────────────────────────

model CampaignMembership {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  role       Role
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@unique([userId, campaignId])
  @@index([campaignId])
  @@index([userId])
  @@map("campaign_memberships")
}

// ─── Address ─────────────────────────────────────────────────────────────────

model Address {
  id           String    @id @default(cuid())
  campaignId   String
  streetNumber String
  streetName   String
  unitNumber   String?
  city         String
  province     String    @default("ON")
  postalCode   String
  lat          Float?
  lng          Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  campaign   Campaign    @relation(fields: [campaignId], references: [id])
  households Household[]

  @@map("addresses")
}

// ─── Household ───────────────────────────────────────────────────────────────

model Household {
  id         String    @id @default(cuid())
  campaignId String
  addressId  String
  name       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  address  Address  @relation(fields: [addressId], references: [id])
  people   Person[]

  @@map("households")
}

// ─── Person ──────────────────────────────────────────────────────────────────

model Person {
  id          String    @id @default(cuid())
  campaignId  String
  householdId String?
  firstName   String
  lastName    String
  email       String?
  phoneHome   String?
  phoneMobile String?
  birthYear    Int?
  supportLevel String?
  gender       String?
  // Tracks data import source / quality notes for deduplication
  sourceNotes String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign           Campaign           @relation(fields: [campaignId], references: [id])
  household          Household?         @relation(fields: [householdId], references: [id])
  tags               PersonTag[]
  notes              Note[]
  canvassResponses   CanvassResponse[]
  canvassListEntries CanvassListEntry[]
  outreachLogs       OutreachLog[]
  linkedDonors       Donor[]
  volunteerRecords   VolunteerRecord[]
  tasks              Task[]

  @@index([campaignId, deletedAt])
  @@index([lastName])
  @@index([email])
  @@index([supportLevel])
  @@map("people")
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id    String  @id @default(cuid())
  name  String  @unique
  color String?

  personTags PersonTag[]

  @@map("tags")
}

model PersonTag {
  personId String
  tagId    String

  person Person @relation(fields: [personId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([personId, tagId])
  @@map("person_tags")
}

// ─── Note ────────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  personId  String
  authorId  String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([personId])
  @@map("notes")
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  campaignId  String
  personId    String?
  assignedTo  String?
  title       String
  notes       String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
  person   Person?  @relation(fields: [personId], references: [id])
  assignee User?    @relation(fields: [assignedTo], references: [id])

  @@index([campaignId])
  @@index([assignedTo])
  @@map("tasks")
}

// ─── Canvass List ─────────────────────────────────────────────────────────────

model CanvassList {
  id          String    @id @default(cuid())
  campaignId  String
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign    Campaign            @relation(fields: [campaignId], references: [id])
  assignments CanvassAssignment[]
  entries     CanvassListEntry[]

  @@map("canvass_lists")
}

// ─── Canvass List Entry ───────────────────────────────────────────────────────
// Represents a person planned to be contacted on a walk list.
// Distinct from CanvassResponse, which records what happened at the door.

model CanvassListEntry {
  id            String   @id @default(cuid())
  canvassListId String
  personId      String
  addedById     String
  createdAt     DateTime @default(now())

  canvassList CanvassList @relation(fields: [canvassListId], references: [id])
  person      Person      @relation(fields: [personId], references: [id])
  addedBy     User        @relation(fields: [addedById], references: [id])

  @@unique([canvassListId, personId])
  @@map("canvass_list_entries")
}

// ─── Canvass Assignment ───────────────────────────────────────────────────────

model CanvassAssignment {
  id            String   @id @default(cuid())
  canvassListId String
  canvasserId   String
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  canvassList CanvassList       @relation(fields: [canvassListId], references: [id])
  canvasser   User              @relation(fields: [canvasserId], references: [id])
  responses   CanvassResponse[]

  @@index([canvassListId])
  @@index([canvasserId])
  @@map("canvass_assignments")
}

// ─── Canvass Response ─────────────────────────────────────────────────────────

model CanvassResponse {
  id                String         @id @default(cuid())
  assignmentId      String
  personId          String
  outcome           CanvassOutcome
  supportLevel      SupportLevel?
  signRequest       Boolean        @default(false)
  volunteerInterest Boolean        @default(false)
  donorInterest     Boolean        @default(false)
  notes             String?
  needsFollowUp     Boolean        @default(false)
  respondedAt       DateTime       @default(now())
  createdAt         DateTime       @default(now())

  assignment CanvassAssignment @relation(fields: [assignmentId], references: [id])
  person     Person            @relation(fields: [personId], references: [id])

  @@index([assignmentId])
  @@index([personId])
  @@map("canvass_responses")
}

// ─── Outreach Log ─────────────────────────────────────────────────────────────

model OutreachLog {
  id         String          @id @default(cuid())
  campaignId String
  personId   String
  userId     String?         // null for records imported without a matching system user
  channel    OutreachChannel
  date       DateTime        @default(now())
  outcome    String?
  notes      String?
  phonedBy   String?         // phone banking: name of caller (may not be a system user)
  phoneType  String?         // phone banking: cell / landline / etc
  createdAt  DateTime        @default(now())
  deletedAt  DateTime?

  campaign Campaign  @relation(fields: [campaignId], references: [id])
  person   Person    @relation(fields: [personId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@index([personId])
  @@map("outreach_logs")
}

// ─── Donor Record ─────────────────────────────────────────────────────────────

// V1: prospect tracking only — no payment processing
model Donor {
  id             String         @id @default(cuid())
  campaignId     String

  // Contact info — stored directly (donor may not be in voter list)
  firstName      String
  lastName       String
  address        String?
  city           String?
  province       String?
  postalCode     String?
  phoneHome      String?
  phoneMobile    String?
  email          String?

  // Donation details
  amount         Decimal?       @db.Decimal(10, 2)
  donationDate   DateTime?
  status         DonorStatus    @default(interested)
  paymentMethod  PaymentMethod?

  // Thank you tracking
  thankYouSent   Boolean        @default(false)
  thankYouDate   DateTime?

  notes          String?

  // Link to voter record if applicable
  linkedPersonId String?

  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  campaign     Campaign  @relation(fields: [campaignId], references: [id])
  linkedPerson Person?   @relation(fields: [linkedPersonId], references: [id])
  createdBy    User?     @relation(fields: [createdById], references: [id])

  @@index([campaignId])
  @@index([linkedPersonId])
  @@map("donors")
}

enum DonorStatus {
  interested
  pledged
  received
}

enum PaymentMethod {
  cash
  cheque
  e_transfer
  other
}

// ─── Volunteer Record ─────────────────────────────────────────────────────────

// Tracks individuals who expressed volunteer interest (from canvassing) or
// have been manually marked as committed. One record per person per campaign.
model VolunteerRecord {
  id         String          @id @default(cuid())
  campaignId String
  personId   String
  status     VolunteerStatus @default(interested)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  campaign Campaign         @relation(fields: [campaignId], references: [id])
  person   Person           @relation(fields: [personId], references: [id])
  shifts   VolunteerShiftAttendee[]

  @@unique([campaignId, personId])
  @@map("volunteer_records")
}

enum VolunteerStatus {
  interested
  committed
}

// ─── Volunteer Shifts ─────────────────────────────────────────────────────────

model VolunteerShift {
  id            String    @id @default(cuid())
  campaignId    String
  name          String
  date          DateTime  // date of the shift (time portion ignored — use startTime/endTime)
  startTime     String    // "09:00"
  endTime       String    // "12:00"
  location      String?
  notes         String?
  maxVolunteers Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  campaign  Campaign                 @relation(fields: [campaignId], references: [id])
  attendees VolunteerShiftAttendee[]

  @@map("volunteer_shifts")
}

model VolunteerShiftAttendee {
  id         String                   @id @default(cuid())
  shiftId    String
  recordId   String                   // FK to VolunteerRecord
  status     VolunteerAttendanceStatus @default(pending)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  shift  VolunteerShift  @relation(fields: [shiftId], references: [id])
  record VolunteerRecord @relation(fields: [recordId], references: [id])

  @@unique([shiftId, recordId])
  @@map("volunteer_shift_attendees")
}

enum VolunteerAttendanceStatus {
  pending
  attended
  no_show
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  campaignId String?
  userId     String?
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@map("audit_logs")
}
