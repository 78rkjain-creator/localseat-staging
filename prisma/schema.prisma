generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  candidate
  campaign_manager
  co_chair
  field_organizer
  canvasser
  volunteer_coordinator
  finance_lead
  sign_installer
}

enum SupportLevel {
  strong_yes
  soft_yes
  undecided
  soft_no
  strong_no
  not_home
}

enum CanvassOutcome {
  contacted
  not_home
  refused
  moved
  unavailable
  deceased
  other_candidate
}

enum OutreachChannel {
  door_knock
  phone_call
  email
  text_message
  in_person
  other
}

enum AddressChangeStatus {
  pending
  approved
  rejected
}

enum PlanTier {
  starter
  campaign
  election
  demo
}

enum WardStatus {
  not_checked
  inside
  outside
  outside_accepted
  pending_review
}

enum ElectionType {
  federal
  provincial
  municipal
}

enum SignStatus {
  to_be_installed
  installed
}

enum TaskType {
  general
  volunteer_follow_up
}

enum SignLocationType {
  residential
  non_residential
}

enum ListImportType {
  list
  official_voters_list
  telephone_list
}

enum ListSource {
  voters_list
  residents_list
  manual
  canvass
  team
}

enum OutOfDistrictApprovalStatus {
  pending
  approved
  rejected
  not_required
}

enum PersonListMembershipStatus {
  matched
  created
  pending_review
  accepted
}

// ─── Campaign ─────────────────────────────────────────────────────────────────

model Campaign {
  id           String   @id @default(cuid())
  name         String
  ballotName   String?
  officeSought String?
  description  String?
  municipality String?
  wards        String[]
  city         String
  province     String   @default("ON")
  year         Int
  electionDate DateTime?
  wardBoundary      Json?
  wardBoundarySetAt DateTime?
  canvassScript     String?
  customFields      Json?
  isActive       Boolean   @default(true)
  plan           PlanTier  @default(starter)
  planActivated  Boolean   @default(true)
  amountPaid     Int?
  planLockedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  memberships   CampaignMembership[]
  people        Person[]
  households    Household[]
  addresses     Address[]
  canvassLists  CanvassList[]
  outreachLogs  OutreachLog[]
  donors           Donor[]
  volunteerRecords VolunteerRecord[]
  volunteerShifts  VolunteerShift[]
  auditLogs        AuditLog[]
  tasks            Task[]
  addressChangeRequests AddressChangeRequest[]
  override              CampaignOverride?
  competitors           CampaignCompetitor[]
  votingRecords         VotingRecord[]
  voterChangeRequests   VoterChangeRequest[]
  listImports           ListImport[]
  personListMemberships PersonListMembership[]
  signs                 Sign[]
  tags                  Tag[]

  @@index([deletedAt])
  @@map("campaigns")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phoneHome    String?
  phoneMobile  String?
  isActive                  Boolean   @default(true)
  platformRole              String?
  emailVerified             DateTime?
  verificationToken         String?   @unique
  verificationTokenExpiry   DateTime?
  passwordResetToken        String?   @unique
  passwordResetTokenExpiry  DateTime?
  termsAcceptedAt           DateTime?
  termsSignedName           String?
  termsVersion              String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  memberships          CampaignMembership[]
  canvassAssignments   CanvassAssignment[]
  canvassListEntries   CanvassListEntry[]
  notes                Note[]
  tasksAssigned        Task[]
  outreachLogs         OutreachLog[]
  auditLogs            AuditLog[]
  donorsCreated        Donor[]
  addressChangeRequests AddressChangeRequest[] @relation("AddressChangeRequests")
  addressChangeReviews  AddressChangeRequest[] @relation("AddressChangeReviews")
  submittedVoterChanges VoterChangeRequest[]   @relation("VoterChangeSubmitter")
  reviewedVoterChanges  VoterChangeRequest[]   @relation("VoterChangeReviewer")
  listImports           ListImport[]           @relation("ListImportUser")
  personRecords         Person[]
  signsAdded            Sign[]                 @relation("SignsAdded")
  signsInstalled        Sign[]                 @relation("SignsInstalled")

  @@index([deletedAt])
  @@index([platformRole])
  @@map("users")
}

// ─── Campaign Membership ──────────────────────────────────────────────────────

model CampaignMembership {
  id         String   @id @default(cuid())
  userId     String
  campaignId String
  role       Role
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  user     User     @relation(fields: [userId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@unique([userId, campaignId])
  @@index([campaignId])
  @@index([userId])
  @@index([deletedAt])
  @@map("campaign_memberships")
}

// ─── Address ─────────────────────────────────────────────────────────────────

model Address {
  id           String    @id @default(cuid())
  campaignId   String
  streetNumber String
  streetName   String
  unitNumber   String?
  city         String
  province     String    @default("ON")
  postalCode   String
  lat          Float?
  lng          Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  campaign   Campaign    @relation(fields: [campaignId], references: [id])
  households Household[]
  signs      Sign[]

  @@map("addresses")
}

// ─── Household ───────────────────────────────────────────────────────────────

model Household {
  id         String    @id @default(cuid())
  campaignId String
  addressId  String
  name       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  address  Address  @relation(fields: [addressId], references: [id])
  people   Person[]

  @@map("households")
}

// ─── Person ──────────────────────────────────────────────────────────────────

model Person {
  id          String    @id @default(cuid())
  campaignId  String
  householdId String?
  firstName   String
  lastName    String
  email       String?
  phoneHome   String?
  phoneMobile String?
  birthDate    DateTime?
  supportLevel SupportLevel?
  gender       String?
  pollNumber   String?
  importSource String?
  // Tracks data import source / quality notes for deduplication
  sourceNotes String?
  wardStatus          WardStatus @default(not_checked)
  isConfirmedVoter    Boolean    @default(false)
  listSource          ListSource @default(manual)
  includeInWalkLists  Boolean    @default(false)
  isOutOfDistrict             Boolean                      @default(false)
  outOfDistrictApprovalStatus OutOfDistrictApprovalStatus?
  userId                      String?
  needsDistrictClassification Boolean                      @default(false)
  customFieldValues   Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign           Campaign           @relation(fields: [campaignId], references: [id])
  household          Household?         @relation(fields: [householdId], references: [id])
  user               User?              @relation(fields: [userId], references: [id])
  tags               PersonTag[]
  notes              Note[]
  canvassResponses   CanvassResponse[]
  canvassListEntries CanvassListEntry[]
  outreachLogs       OutreachLog[]
  linkedDonors       Donor[]
  volunteerRecords   VolunteerRecord[]
  tasks              Task[]
  addressChangeRequests AddressChangeRequest[]
  votingRecords         VotingRecord[]
  voterChangeRequests   VoterChangeRequest[]
  listMemberships       PersonListMembership[]

  @@unique([userId, campaignId])
  @@index([campaignId, deletedAt])
  @@index([lastName])
  @@index([email])
  @@index([supportLevel])
  @@map("people")
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id         String    @id @default(cuid())
  campaignId String
  name       String
  color      String?
  deletedAt  DateTime?

  campaign   Campaign   @relation(fields: [campaignId], references: [id])
  personTags PersonTag[]

  @@unique([campaignId, name])
  @@index([deletedAt])
  @@map("tags")
}

model PersonTag {
  personId  String
  tagId     String
  deletedAt DateTime?

  person Person @relation(fields: [personId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([personId, tagId])
  @@index([deletedAt])
  @@map("person_tags")
}

// ─── Note ────────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  personId  String
  authorId  String
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  person Person @relation(fields: [personId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([personId])
  @@index([deletedAt])
  @@map("notes")
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  campaignId  String
  personId    String?
  assignedTo  String?
  type        TaskType  @default(general)
  title       String
  notes       String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  person   Person?  @relation(fields: [personId], references: [id])
  assignee User?    @relation(fields: [assignedTo], references: [id])

  @@index([campaignId])
  @@index([assignedTo])
  @@index([deletedAt])
  @@map("tasks")
}

// ─── Canvass List ─────────────────────────────────────────────────────────────

model CanvassList {
  id             String    @id @default(cuid())
  campaignId     String
  name           String
  description    String?
  turfPolygon    Json?     // GeoJSON polygon from map-based turf cutting; null for manual/CSV lists
  turfCreatedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  campaign    Campaign            @relation(fields: [campaignId], references: [id])
  assignments CanvassAssignment[]
  entries     CanvassListEntry[]

  @@map("canvass_lists")
}

// ─── Canvass List Entry ───────────────────────────────────────────────────────
// Represents a person planned to be contacted on a walk list.
// Distinct from CanvassResponse, which records what happened at the door.

model CanvassListEntry {
  id            String   @id @default(cuid())
  canvassListId String
  personId      String
  addedById     String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  canvassList CanvassList @relation(fields: [canvassListId], references: [id])
  person      Person      @relation(fields: [personId], references: [id])
  addedBy     User        @relation(fields: [addedById], references: [id])

  @@unique([canvassListId, personId])
  @@index([deletedAt])
  @@map("canvass_list_entries")
}

// ─── Canvass Assignment ───────────────────────────────────────────────────────

model CanvassAssignment {
  id            String   @id @default(cuid())
  canvassListId String
  canvasserId   String
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  canvassList CanvassList       @relation(fields: [canvassListId], references: [id])
  canvasser   User              @relation(fields: [canvasserId], references: [id])
  responses   CanvassResponse[]

  @@index([canvassListId])
  @@index([canvasserId])
  @@index([deletedAt])
  @@map("canvass_assignments")
}

// ─── Canvass Response ─────────────────────────────────────────────────────────

model CanvassResponse {
  id                String         @id @default(cuid())
  assignmentId      String
  personId          String
  outcome           CanvassOutcome
  supportLevel      SupportLevel?
  signRequest       Boolean        @default(false)
  volunteerInterest Boolean        @default(false)
  donorInterest     Boolean        @default(false)
  notes             String?
  needsFollowUp     Boolean        @default(false)
  respondedAt       DateTime       @default(now())
  createdAt         DateTime       @default(now())
  competitorId      String?

  assignment CanvassAssignment  @relation(fields: [assignmentId], references: [id])
  person     Person             @relation(fields: [personId], references: [id])
  competitor CampaignCompetitor? @relation(fields: [competitorId], references: [id])

  // One response per person per assignment — prevents duplicate submissions from
  // network retries or offline queue re-syncs. Use upsert when saving.
  @@unique([assignmentId, personId])
  @@index([assignmentId])
  @@index([personId])
  @@index([competitorId])
  @@map("canvass_responses")
}

// ─── Outreach Log ─────────────────────────────────────────────────────────────

model OutreachLog {
  id         String          @id @default(cuid())
  campaignId String
  personId   String
  userId     String?         // null for records imported without a matching system user
  channel    OutreachChannel
  date       DateTime        @default(now())
  outcome    String?
  notes      String?
  phonedBy   String?         // phone banking: name of caller (may not be a system user)
  phoneType  String?         // phone banking: cell / landline / etc
  createdAt  DateTime        @default(now())
  deletedAt  DateTime?

  campaign Campaign  @relation(fields: [campaignId], references: [id])
  person   Person    @relation(fields: [personId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@index([personId])
  @@map("outreach_logs")
}

// ─── Donor Record ─────────────────────────────────────────────────────────────

// V1: prospect tracking only — no payment processing
model Donor {
  id             String         @id @default(cuid())
  campaignId     String

  // Contact info — stored directly (donor may not be in voter list)
  firstName      String
  lastName       String
  address        String?
  city           String?
  province       String?
  postalCode     String?
  phoneHome      String?
  phoneMobile    String?
  email          String?

  // Donation details
  amount         Decimal?       @db.Decimal(10, 2)
  donationDate   DateTime?
  status         DonorStatus    @default(interested)
  paymentMethod  PaymentMethod?

  // Thank you tracking
  thankYouSent   Boolean        @default(false)
  thankYouDate   DateTime?

  notes          String?

  // Link to voter record if applicable
  linkedPersonId String?

  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  campaign     Campaign  @relation(fields: [campaignId], references: [id])
  linkedPerson Person?   @relation(fields: [linkedPersonId], references: [id])
  createdBy    User?     @relation(fields: [createdById], references: [id])

  @@index([campaignId])
  @@index([linkedPersonId])
  @@map("donors")
}

enum DonorStatus {
  interested
  pledged
  received
}

enum PaymentMethod {
  cash
  cheque
  e_transfer
  other
}

// ─── Volunteer Record ─────────────────────────────────────────────────────────

// Tracks individuals who expressed volunteer interest (from canvassing) or
// have been manually marked as committed. One record per person per campaign.
model VolunteerRecord {
  id         String          @id @default(cuid())
  campaignId String
  personId   String
  status     VolunteerStatus @default(interested)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  campaign Campaign         @relation(fields: [campaignId], references: [id])
  person   Person           @relation(fields: [personId], references: [id])
  shifts   VolunteerShiftAttendee[]

  @@unique([campaignId, personId])
  @@map("volunteer_records")
}

enum VolunteerStatus {
  interested
  committed
}

// ─── Volunteer Shifts ─────────────────────────────────────────────────────────

model VolunteerShift {
  id            String    @id @default(cuid())
  campaignId    String
  name          String
  date          DateTime  // date of the shift (time portion ignored — use startTime/endTime)
  startTime     String    // "09:00"
  endTime       String    // "12:00"
  location      String?
  notes         String?
  maxVolunteers Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  campaign  Campaign                 @relation(fields: [campaignId], references: [id])
  attendees VolunteerShiftAttendee[]

  @@map("volunteer_shifts")
}

model VolunteerShiftAttendee {
  id         String                   @id @default(cuid())
  shiftId    String
  recordId   String                   // FK to VolunteerRecord
  status     VolunteerAttendanceStatus @default(pending)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  deletedAt  DateTime?

  shift  VolunteerShift  @relation(fields: [shiftId], references: [id])
  record VolunteerRecord @relation(fields: [recordId], references: [id])

  @@unique([shiftId, recordId])
  @@index([deletedAt])
  @@map("volunteer_shift_attendees")
}

enum VolunteerAttendanceStatus {
  pending
  attended
  no_show
}

// ─── Address Change Request ───────────────────────────────────────────────────
// Canvassers and field staff submit address corrections.
// Campaign managers / field organizers review and approve or reject.

model AddressChangeRequest {
  id                String              @id @default(cuid())
  campaignId        String
  requestedByUserId String
  reviewedByUserId  String?
  personId          String
  // JSON array of person IDs to move (may be subset of the household)
  affectedPersonIds String[]
  // Snapshot of the old address for audit purposes
  oldAddressId      String?
  // New address data as submitted
  newAddressData    Json
  status            AddressChangeStatus @default(pending)
  createdAt         DateTime            @default(now())
  reviewedAt        DateTime?
  deletedAt         DateTime?

  campaign    Campaign @relation(fields: [campaignId], references: [id])
  requestedBy User     @relation("AddressChangeRequests", fields: [requestedByUserId], references: [id])
  reviewedBy  User?    @relation("AddressChangeReviews", fields: [reviewedByUserId], references: [id])
  person      Person   @relation(fields: [personId], references: [id])

  @@index([campaignId, status])
  @@index([personId])
  @@map("address_change_requests")
}

// ─── Demo Registration ────────────────────────────────────────────────────────
// Captures lead information from the public demo landing page.
// No campaign or user FK — intentionally standalone.

model DemoRegistration {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  municipality String?
  officeType   String?
  consented    Boolean   @default(false)
  source       String?
  createdAt    DateTime  @default(now())
  ipAddress    String?
  emailedAt    DateTime?

  @@map("demo_registrations")
}

// ─── Contact Submission ───────────────────────────────────────────────────────

model ContactSubmission {
  id        String    @id @default(cuid())
  firstName String
  lastName  String
  email     String
  topic     String?
  message   String
  ipAddress String?
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@map("contact_submissions")
}

// ─── Platform Settings ────────────────────────────────────────────────────────

model PlatformSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("platform_settings")
}

// ─── Campaign Override ────────────────────────────────────────────────────────

model CampaignOverride {
  id                   String   @id @default(cuid())
  campaignId           String   @unique
  campaign             Campaign @relation(fields: [campaignId], references: [id])
  canvasserLimit       Int?
  constituentLimit     Int?
  extraCanvassers      Int?
  coChairLimit         Int?
  fieldOrganizerLimit  Int?
  donorTrackingEnabled Boolean?
  notesInternal        String?
  grantedBy            String?
  grantedAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("campaign_overrides")
}

model CampaignCompetitor {
  id         String    @id @default(cuid())
  campaignId String
  name       String
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  campaign          Campaign          @relation(fields: [campaignId], references: [id])
  canvassResponses  CanvassResponse[]

  @@index([campaignId])
  @@index([deletedAt])
  @@map("campaign_competitors")
}

// ─── Sign ─────────────────────────────────────────────────────────────────────

model Sign {
  id             String          @id @default(cuid())
  campaignId     String
  status         SignStatus      @default(to_be_installed)
  locationType   SignLocationType
  addressId      String?
  locationText   String?
  notes          String?
  addedById      String
  installedById  String?
  installedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  campaign    Campaign @relation(fields: [campaignId], references: [id])
  address     Address? @relation(fields: [addressId], references: [id])
  addedBy     User     @relation("SignsAdded", fields: [addedById], references: [id])
  installedBy User?    @relation("SignsInstalled", fields: [installedById], references: [id])

  @@index([campaignId])
  @@index([deletedAt])
  @@map("signs")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  campaignId String?
  userId     String?
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@map("audit_logs")
}

// ─── VotingRecord ─────────────────────────────────────────────────────────────

model VotingRecord {
  id           String       @id @default(cuid())
  campaignId   String
  personId     String
  electionType ElectionType
  electionYear Int
  electionName String?
  participated Boolean      @default(false)
  partySupport String?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  person   Person   @relation(fields: [personId], references: [id])

  @@index([campaignId])
  @@index([personId])
  @@index([deletedAt])
  @@map("voting_records")
}

// ─── Voter Change Request ─────────────────────────────────────────────────────
// Canvassers submit record corrections from the canvass screen.
// Managers / organizers review and apply or reject.

model VoterChangeRequest {
  id                String              @id @default(cuid())
  campaignId        String
  submittedByUserId String
  reviewedByUserId  String?
  personId          String?
  requestType       String?             @default("field_edit")
  proposedChanges   Json
  currentSnapshot   Json?
  status            AddressChangeStatus @default(pending)
  rejectionReason   String?
  createdAt         DateTime            @default(now())
  reviewedAt        DateTime?
  deletedAt         DateTime?

  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  submittedBy User      @relation("VoterChangeSubmitter", fields: [submittedByUserId], references: [id])
  reviewedBy  User?     @relation("VoterChangeReviewer", fields: [reviewedByUserId], references: [id])
  person      Person?   @relation(fields: [personId], references: [id])

  @@index([campaignId, status])
  @@index([personId])
  @@index([deletedAt])
  @@map("voter_change_requests")
}

// ─── ListImport ───────────────────────────────────────────────────────────────

model ListImport {
  id             String          @id @default(cuid())
  campaignId     String
  name           String
  type           ListImportType
  importedAt     DateTime        @default(now())
  importedById   String
  totalRows      Int
  matchedCount   Int             @default(0)
  newCount       Int             @default(0)
  reviewCount    Int             @default(0)

  campaign     Campaign              @relation(fields: [campaignId], references: [id])
  importedBy   User                  @relation("ListImportUser", fields: [importedById], references: [id])
  memberships  PersonListMembership[]

  @@index([campaignId])
  @@map("list_imports")
}

// ─── PersonListMembership ─────────────────────────────────────────────────────

model PersonListMembership {
  id            String                     @id @default(cuid())
  personId      String
  listImportId  String
  campaignId    String
  status        PersonListMembershipStatus
  reviewReason  String?
  createdAt     DateTime                   @default(now())

  person      Person     @relation(fields: [personId], references: [id])
  listImport  ListImport @relation(fields: [listImportId], references: [id])
  campaign    Campaign   @relation(fields: [campaignId], references: [id])

  @@unique([personId, listImportId])
  @@index([listImportId])
  @@index([campaignId])
  @@map("person_list_memberships")
}
