generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  candidate
  campaign_manager
  data_manager
  co_chair
  field_organizer
  canvasser
  volunteer_coordinator
  finance_lead
  sign_installer
  data_supplier
}

enum SupportLevel {
  strong_yes
  soft_yes
  undecided
  soft_no
  strong_no
  not_home
}

enum CanvassOutcome {
  contacted
  not_home
  refused
  moved
  unavailable
  deceased
  other_candidate
  language_barrier
}

enum OutreachChannel {
  door_knock
  phone_call
  email
  text_message
  in_person
  other
}

enum AddressChangeStatus {
  pending
  approved
  rejected
}

enum PlanTier {
  bench
  chair
  podium
  stage
  arena
  demo
}

enum CanvassListStatus {
  draft
  pending_approval
  active
  archived
}

enum WardStatus {
  not_checked
  inside
  outside
  outside_accepted
  pending_review
}

enum ElectionType {
  federal
  provincial
  municipal
}

enum SignStatus {
  to_be_installed
  installed
}

enum TaskType {
  general
  volunteer_follow_up
  appointment
}

enum FieldMessagePriority {
  normal
  urgent
}

enum SurveyQuestionType {
  text
  single_choice
  multi_choice
  rating
  yes_no
}

enum EventType {
  campaign_event
  fundraiser
  town_hall
  debate
  canvass_kickoff
  volunteer_training
  other
}

enum EventStatus {
  upcoming
  in_progress
  completed
  cancelled
}

enum EventAttendeeStatus {
  invited
  confirmed
  attended
  no_show
}

enum SignLocationType {
  residential
  non_residential
}

enum ListImportType {
  list
  official_voters_list
  telephone_list
}

enum ListSource {
  voters_list
  residents_list
  manual
  canvass
  team
}

enum OutOfDistrictApprovalStatus {
  pending
  approved
  rejected
  not_required
}

enum PersonListMembershipStatus {
  matched
  created
  pending_review
  accepted
}

// ─── Campaign ─────────────────────────────────────────────────────────────────

model Campaign {
  id           String   @id @default(cuid())
  name         String
  ballotName   String?
  officeSought String?
  description  String?
  municipality         String?
  municipalityName     String?
  municipalityId       String?
  municipalityBoundary Json?
  wards        String[]
  city         String
  province     String   @default("ON")
  year         Int
  electionDate         DateTime?
  fundraisingGoal      Int?
  wardBoundary      Json?
  wardBoundarySetAt DateTime?
  canvassScript        String?
  customFields         Json?
  dailySummaryEnabled  Boolean   @default(false)
  dailySummaryEmail    String?
  dataRetentionMonths  Int?
  advanceVotingDates   DateTime[]
  officeAddressStreetNumber String?
  officeAddressStreetName   String?
  officeAddressUnitNumber   String?
  officeAddressCity         String?
  officeAddressProvince     String?
  officeAddressPostalCode   String?
  officeAddressLat          Float?
  officeAddressLng          Float?
  isActive       Boolean   @default(true)
  plan           PlanTier  @default(bench)
  planActivated  Boolean   @default(true)
  amountPaid     Int?
  planLockedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  memberships   CampaignMembership[]
  people        Person[]
  households    Household[]
  addresses     Address[]
  canvassLists  CanvassList[]
  outreachLogs  OutreachLog[]
  donors           Donor[]
  volunteerRecords VolunteerRecord[]
  volunteerShifts  VolunteerShift[]
  auditLogs        AuditLog[]
  tasks            Task[]
  addressChangeRequests AddressChangeRequest[]
  override              CampaignOverride?
  competitors           CampaignCompetitor[]
  votingRecords         VotingRecord[]
  voterChangeRequests   VoterChangeRequest[]
  listImports           ListImport[]
  personListMemberships PersonListMembership[]
  signs                 Sign[]
  tags                  Tag[]
  events                Event[]
  fieldMessages         FieldMessage[]
  surveys               Survey[]
  signatureRecords      SignatureRecord[]
  signatureConsentTypes SignatureConsentType[]
  supportAccessGrants   SupportAccessGrant[]
  dataImports           DataImport[]
  supplierAcknowledgements SupplierAcknowledgement[]
  promoCode             PromoCode?  @relation(fields: [promoCodeId], references: [id])
  promoCodeId           String?

  @@index([deletedAt])
  @@map("campaigns")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phoneHome    String?
  phoneMobile  String?
  isActive                  Boolean   @default(true)
  platformRole              String?
  emailVerified             DateTime?
  verificationToken         String?   @unique
  verificationTokenExpiry   DateTime?
  passwordResetToken        String?   @unique
  passwordResetTokenExpiry  DateTime?
  termsAcceptedAt           DateTime?
  termsSignedName           String?
  termsVersion              String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  sessionVersion Int       @default(0)

  memberships          CampaignMembership[]
  canvassAssignments   CanvassAssignment[]
  canvassListEntries   CanvassListEntry[]
  notes                Note[]
  tasksAssigned        Task[]
  outreachLogs         OutreachLog[]
  auditLogs            AuditLog[]
  donorsCreated        Donor[]
  addressChangeRequests AddressChangeRequest[] @relation("AddressChangeRequests")
  addressChangeReviews  AddressChangeRequest[] @relation("AddressChangeReviews")
  submittedVoterChanges VoterChangeRequest[]   @relation("VoterChangeSubmitter")
  reviewedVoterChanges  VoterChangeRequest[]   @relation("VoterChangeReviewer")
  listImports           ListImport[]           @relation("ListImportUser")
  personRecords         Person[]
  signsAdded                Sign[]   @relation("SignsAdded")
  signsInstalled            Sign[]   @relation("SignsInstalled")
  outOfDistrictRequests     Person[] @relation("OodRequester")
  eventsCreated             Event[]  @relation("EventCreator")
  eventAttendances          EventAttendee[]
  fieldMessagesCreated      FieldMessage[]   @relation("FieldMessageAuthor")
  surveysCreated            Survey[]         @relation("SurveyCreator")
  surveyResponses           SurveyResponse[] @relation("SurveyResponder")
  signaturesCollected       SignatureRecord[] @relation("SignatureCollector")
  supportAccessRequestsBy   SupportAccessGrant[] @relation("SupportAccessRequestedBy")
  supportAccessApprovals    SupportAccessGrant[] @relation("SupportAccessApprovedBy")
  supportAccessRevocations  SupportAccessGrant[] @relation("SupportAccessRevokedBy")
  supportAccessDenials      SupportAccessGrant[] @relation("SupportAccessDeniedBy")
  dataImportsUploaded       DataImport[]         @relation("DataImportUploadedBy")
  dataImportsReviewed       DataImport[]         @relation("DataImportReviewedBy")
  supplierAcknowledgementsSigned SupplierAcknowledgement[] @relation("SupplierAcknowledgementSigner")

  @@index([deletedAt])
  @@index([platformRole])
  @@map("users")
}

// ─── Campaign Membership ──────────────────────────────────────────────────────

model CampaignMembership {
  id           String   @id @default(cuid())
  userId       String
  campaignId   String
  role         Role
  company      String?
  companyPhone String?
  companyEmail String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  user     User     @relation(fields: [userId], references: [id])
  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@unique([userId, campaignId])
  @@index([campaignId])
  @@index([userId])
  @@index([deletedAt])
  @@map("campaign_memberships")
}

// ─── Address ─────────────────────────────────────────────────────────────────

model Address {
  id           String    @id @default(cuid())
  campaignId   String
  streetNumber String
  streetName   String
  unitNumber   String?
  city         String
  province     String    @default("ON")
  postalCode   String
  lat          Float?
  lng          Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  campaign   Campaign    @relation(fields: [campaignId], references: [id])
  households Household[]
  signs      Sign[]

  @@map("addresses")
}

// ─── Household ───────────────────────────────────────────────────────────────

model Household {
  id         String    @id @default(cuid())
  campaignId String
  addressId  String
  name       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  address  Address  @relation(fields: [addressId], references: [id])
  people   Person[]

  @@map("households")
}

// ─── Person ──────────────────────────────────────────────────────────────────

model Person {
  id          String    @id @default(cuid())
  campaignId  String
  householdId String?
  firstName   String
  lastName    String
  email       String?
  phoneHome   String?
  phoneMobile String?
  birthDate    DateTime?
  supportLevel SupportLevel?
  gender       String?
  pollNumber   String?
  importSource String?
  // Tracks data import source / quality notes for deduplication
  sourceNotes String?
  wardStatus          WardStatus @default(not_checked)
  isConfirmedVoter    Boolean    @default(false)
  listSource          ListSource @default(manual)
  includeInWalkLists  Boolean    @default(false)
  isOutOfDistrict              Boolean                      @default(false)
  outOfDistrictApprovalStatus  OutOfDistrictApprovalStatus?
  outOfDistrictRequestedById   String?
  outOfDistrictRequestedAt     DateTime?
  outOfDistrictRejectionReason String?
  userId                       String?
  needsDistrictClassification  Boolean                      @default(false)
  customFieldValues   Json?
  availability        String?
  voterId             String?
  anonymizedAt        DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign                 Campaign           @relation(fields: [campaignId], references: [id])
  household                Household?         @relation(fields: [householdId], references: [id])
  user                     User?              @relation(fields: [userId], references: [id])
  outOfDistrictRequester   User?              @relation("OodRequester", fields: [outOfDistrictRequestedById], references: [id])
  tags               PersonTag[]
  notes              Note[]
  canvassResponses   CanvassResponse[]
  canvassListEntries CanvassListEntry[]
  outreachLogs       OutreachLog[]
  linkedDonors       Donor[]
  volunteerRecords   VolunteerRecord[]
  tasks              Task[]
  addressChangeRequests AddressChangeRequest[]
  votingRecords         VotingRecord[]
  voterChangeRequests   VoterChangeRequest[]
  listMemberships       PersonListMembership[]
  surveyResponses       SurveyResponse[]
  signatureRecords      SignatureRecord[]

  @@unique([userId, campaignId])
  @@unique([campaignId, voterId])
  @@index([campaignId, deletedAt])
  @@index([lastName])
  @@index([email])
  @@index([supportLevel])
  @@map("people")
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id         String    @id @default(cuid())
  campaignId String
  name       String
  color      String?
  deletedAt  DateTime?

  campaign   Campaign   @relation(fields: [campaignId], references: [id])
  personTags PersonTag[]

  @@unique([campaignId, name])
  @@index([deletedAt])
  @@map("tags")
}

model PersonTag {
  personId  String
  tagId     String
  deletedAt DateTime?

  person Person @relation(fields: [personId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([personId, tagId])
  @@index([deletedAt])
  @@map("person_tags")
}

// ─── Note ────────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(cuid())
  personId  String
  authorId  String
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  person Person @relation(fields: [personId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([personId])
  @@index([deletedAt])
  @@map("notes")
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  campaignId  String
  personId    String?
  assignedTo  String?
  type        TaskType  @default(general)
  title       String
  notes       String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  person   Person?  @relation(fields: [personId], references: [id])
  assignee User?    @relation(fields: [assignedTo], references: [id])

  @@index([campaignId])
  @@index([assignedTo])
  @@index([deletedAt])
  @@map("tasks")
}

// ─── Canvass List ─────────────────────────────────────────────────────────────

model CanvassList {
  id              String            @id @default(cuid())
  campaignId      String
  name            String
  description     String?
  turfPolygon     Json?             // GeoJSON polygon from map-based turf cutting; null for manual/CSV lists
  turfCreatedAt   DateTime?
  status          CanvassListStatus @default(active)
  rejectionReason String?
  dynamicFilters  Json?             // DynamicFilters JSON when isDynamic; null for static lists
  lastRefreshedAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  campaign    Campaign            @relation(fields: [campaignId], references: [id])
  assignments CanvassAssignment[]
  entries     CanvassListEntry[]
  events      Event[]

  @@map("canvass_lists")
}

// ─── Canvass List Entry ───────────────────────────────────────────────────────
// Represents a person planned to be contacted on a walk list.
// Distinct from CanvassResponse, which records what happened at the door.

model CanvassListEntry {
  id            String   @id @default(cuid())
  canvassListId String
  personId      String
  addedById     String
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  canvassList CanvassList @relation(fields: [canvassListId], references: [id])
  person      Person      @relation(fields: [personId], references: [id])
  addedBy     User        @relation(fields: [addedById], references: [id])

  @@unique([canvassListId, personId])
  @@index([deletedAt])
  @@map("canvass_list_entries")
}

// ─── Canvass Assignment ───────────────────────────────────────────────────────

model CanvassAssignment {
  id            String   @id @default(cuid())
  canvassListId String
  canvasserId   String
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  canvassList CanvassList       @relation(fields: [canvassListId], references: [id])
  canvasser   User              @relation(fields: [canvasserId], references: [id])
  responses   CanvassResponse[]

  @@index([canvassListId])
  @@index([canvasserId])
  @@index([deletedAt])
  @@map("canvass_assignments")
}

// ─── Canvass Response ─────────────────────────────────────────────────────────

model CanvassResponse {
  id                String         @id @default(cuid())
  assignmentId      String
  personId          String
  outcome           CanvassOutcome
  supportLevel      SupportLevel?
  outcomeDetail     String?
  signRequest       Boolean        @default(false)
  volunteerInterest Boolean        @default(false)
  donorInterest     Boolean        @default(false)
  notes             String?
  needsFollowUp     Boolean        @default(false)
  respondedAt       DateTime       @default(now())
  createdAt         DateTime       @default(now())
  competitorId      String?

  assignment      CanvassAssignment   @relation(fields: [assignmentId], references: [id])
  person          Person              @relation(fields: [personId], references: [id])
  competitor      CampaignCompetitor? @relation(fields: [competitorId], references: [id])
  surveyResponse  SurveyResponse?

  @@index([assignmentId])
  @@index([personId])
  @@index([competitorId])
  @@map("canvass_responses")
}

// ─── Outreach Log ─────────────────────────────────────────────────────────────

model OutreachLog {
  id         String          @id @default(cuid())
  campaignId String
  personId   String
  userId     String?         // null for records imported without a matching system user
  channel    OutreachChannel
  date       DateTime        @default(now())
  outcome    String?
  notes      String?
  phonedBy   String?         // phone banking: name of caller (may not be a system user)
  phoneType  String?         // phone banking: cell / landline / etc
  createdAt  DateTime        @default(now())
  deletedAt  DateTime?

  campaign Campaign  @relation(fields: [campaignId], references: [id])
  person   Person    @relation(fields: [personId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@index([personId])
  @@map("outreach_logs")
}

// ─── Donor Record ─────────────────────────────────────────────────────────────

// V1: prospect tracking only — no payment processing
model Donor {
  id             String         @id @default(cuid())
  campaignId     String

  // Contact info — stored directly (donor may not be in voter list)
  firstName      String
  lastName       String
  address        String?
  city           String?
  province       String?
  postalCode     String?
  phoneHome      String?
  phoneMobile    String?
  email          String?

  // Donation details
  amount         Decimal?       @db.Decimal(10, 2)
  donationDate   DateTime?
  status         DonorStatus    @default(interested)
  paymentMethod  PaymentMethod?

  // Thank you tracking
  thankYouSent   Boolean        @default(false)
  thankYouDate   DateTime?

  notes          String?

  // Link to voter record if applicable
  linkedPersonId String?

  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  campaign     Campaign  @relation(fields: [campaignId], references: [id])
  linkedPerson Person?   @relation(fields: [linkedPersonId], references: [id])
  createdBy    User?     @relation(fields: [createdById], references: [id])

  @@index([campaignId])
  @@index([linkedPersonId])
  @@map("donors")
}

enum DonorStatus {
  interested
  pledged
  received
}

enum PaymentMethod {
  cash
  cheque
  e_transfer
  other
}

// ─── Volunteer Record ─────────────────────────────────────────────────────────

// Tracks individuals who expressed volunteer interest (from canvassing) or
// have been manually marked as committed. One record per person per campaign.
model VolunteerRecord {
  id         String          @id @default(cuid())
  campaignId String
  personId   String
  status     VolunteerStatus @default(interested)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?

  campaign Campaign         @relation(fields: [campaignId], references: [id])
  person   Person           @relation(fields: [personId], references: [id])
  shifts   VolunteerShiftAttendee[]

  @@unique([campaignId, personId])
  @@map("volunteer_records")
}

enum VolunteerStatus {
  interested
  committed
}

// ─── Volunteer Shifts ─────────────────────────────────────────────────────────

model VolunteerShift {
  id            String    @id @default(cuid())
  campaignId    String
  name          String
  date          DateTime  // date of the shift (time portion ignored — use startTime/endTime)
  startTime     String    // "09:00"
  endTime       String    // "12:00"
  location      String?
  notes         String?
  maxVolunteers Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  campaign  Campaign                 @relation(fields: [campaignId], references: [id])
  attendees VolunteerShiftAttendee[]

  @@map("volunteer_shifts")
}

model VolunteerShiftAttendee {
  id         String                   @id @default(cuid())
  shiftId    String
  recordId   String                   // FK to VolunteerRecord
  status     VolunteerAttendanceStatus @default(pending)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  deletedAt  DateTime?

  shift  VolunteerShift  @relation(fields: [shiftId], references: [id])
  record VolunteerRecord @relation(fields: [recordId], references: [id])

  @@unique([shiftId, recordId])
  @@index([deletedAt])
  @@map("volunteer_shift_attendees")
}

enum VolunteerAttendanceStatus {
  pending
  attended
  no_show
}

// ─── Address Change Request ───────────────────────────────────────────────────
// Canvassers and field staff submit address corrections.
// Campaign managers / field organizers review and approve or reject.

model AddressChangeRequest {
  id                String              @id @default(cuid())
  campaignId        String
  requestedByUserId String
  reviewedByUserId  String?
  personId          String
  // JSON array of person IDs to move (may be subset of the household)
  affectedPersonIds String[]
  // Snapshot of the old address for audit purposes
  oldAddressId      String?
  // New address data as submitted
  newAddressData    Json
  status            AddressChangeStatus @default(pending)
  createdAt         DateTime            @default(now())
  reviewedAt        DateTime?
  deletedAt         DateTime?

  campaign    Campaign @relation(fields: [campaignId], references: [id])
  requestedBy User     @relation("AddressChangeRequests", fields: [requestedByUserId], references: [id])
  reviewedBy  User?    @relation("AddressChangeReviews", fields: [reviewedByUserId], references: [id])
  person      Person   @relation(fields: [personId], references: [id])

  @@index([campaignId, status])
  @@index([personId])
  @@map("address_change_requests")
}

// ─── Demo Registration ────────────────────────────────────────────────────────
// Captures lead information from the public demo landing page.
// No campaign or user FK — intentionally standalone.

model DemoRegistration {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String?
  municipality String?
  officeType   String?
  consented    Boolean   @default(false)
  source       String?
  createdAt    DateTime  @default(now())
  ipAddress    String?
  emailedAt    DateTime?

  @@map("demo_registrations")
}

// ─── Contact Submission ───────────────────────────────────────────────────────

model ContactSubmission {
  id        String    @id @default(cuid())
  firstName String
  lastName  String
  email     String
  topic     String?
  message   String
  ipAddress String?
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@map("contact_submissions")
}

// ─── Platform Settings ────────────────────────────────────────────────────────

model PlatformSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("platform_settings")
}

// ─── Campaign Override ────────────────────────────────────────────────────────

model CampaignOverride {
  id                   String   @id @default(cuid())
  campaignId           String   @unique
  campaign             Campaign @relation(fields: [campaignId], references: [id])

  // Manual per-campaign overrides — highest priority, override everything
  canvasserLimit            Int?
  constituentLimit          Int?
  extraCanvassers           Int?
  coChairLimit              Int?
  fieldOrganizerLimit       Int?
  tagLimit                  Int?
  customFieldLimit          Int?
  donorTrackingEnabled      Boolean?
  followUpQueueEnabled      Boolean?
  analyticsEnabled          Boolean?
  eventsEnabled             Boolean?
  surveysEnabled            Boolean?
  digitalSignaturesEnabled  Boolean?
  customFieldsEnabled       Boolean?
  signTrackingEnabled       Boolean?
  contactMapEnabled         Boolean?
  reportsEnabled            Boolean?
  canvassScriptEnabled      Boolean?
  notesInternal             String?
  grantedBy                 String?
  grantedAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  // Snapshot of tier defaults at time of plan selection
  // Used for "best of snapshot vs current" logic — protects existing campaigns
  // from pricing/feature changes made after they signed up.
  snapshotTagLimit              Int?
  snapshotCustomFieldLimit      Int?
  snapshotConstituentLimit      Int?
  snapshotCanvasserLimit        Int?
  snapshotCampaignManagerLimit  Int?
  snapshotCoChairLimit          Int?
  snapshotFieldOrganizerLimit   Int?
  snapshotDonorTracking         Boolean?
  snapshotFollowUpQueue         Boolean?
  snapshotAnalytics             Boolean?
  snapshotVolunteerCoord        Boolean?
  snapshotFinanceLeadAccess     Boolean?
  snapshotCoChairSeats          Boolean?
  snapshotUnlimitedCanvassers   Boolean?
  snapshotUnlimitedConstituents Boolean?
  snapshotEvents                Boolean?
  snapshotSurveys               Boolean?
  snapshotDigitalSignatures     Boolean?
  snapshotCustomFields          Boolean?
  snapshotSignTracking          Boolean?
  snapshotContactMap            Boolean?
  snapshotReports               Boolean?
  snapshotCanvassScript         Boolean?
  snapshotPricePaid             Int?
  snapshotRegularPrice          Int?
  snapshotSalePrice             Int?
  snapshotedAt                  DateTime?

  @@map("campaign_overrides")
}

model CampaignCompetitor {
  id         String    @id @default(cuid())
  campaignId String
  name       String
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  campaign          Campaign          @relation(fields: [campaignId], references: [id])
  canvassResponses  CanvassResponse[]

  @@index([campaignId])
  @@index([deletedAt])
  @@map("campaign_competitors")
}

// ─── Sign ─────────────────────────────────────────────────────────────────────

model Sign {
  id             String          @id @default(cuid())
  campaignId     String
  status         SignStatus      @default(to_be_installed)
  locationType   SignLocationType
  addressId      String?
  locationText   String?
  notes          String?
  addedById      String
  installedById  String?
  installedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  campaign    Campaign @relation(fields: [campaignId], references: [id])
  address     Address? @relation(fields: [addressId], references: [id])
  addedBy     User     @relation("SignsAdded", fields: [addedById], references: [id])
  installedBy User?    @relation("SignsInstalled", fields: [installedById], references: [id])

  @@index([campaignId])
  @@index([deletedAt])
  @@map("signs")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  campaignId String?
  userId     String?
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@index([campaignId])
  @@map("audit_logs")
}

// ─── VotingRecord ─────────────────────────────────────────────────────────────

model VotingRecord {
  id           String       @id @default(cuid())
  campaignId   String
  personId     String
  electionType ElectionType
  electionYear Int
  electionName String?
  participated Boolean      @default(false)
  partySupport String?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id])
  person   Person   @relation(fields: [personId], references: [id])

  @@index([campaignId])
  @@index([personId])
  @@index([deletedAt])
  @@map("voting_records")
}

// ─── Voter Change Request ─────────────────────────────────────────────────────
// Canvassers submit record corrections from the canvass screen.
// Managers / organizers review and apply or reject.

model VoterChangeRequest {
  id                String              @id @default(cuid())
  campaignId        String
  submittedByUserId String
  reviewedByUserId  String?
  personId          String?
  requestType       String?             @default("field_edit")
  proposedChanges   Json
  currentSnapshot   Json?
  status            AddressChangeStatus @default(pending)
  rejectionReason   String?
  createdAt         DateTime            @default(now())
  reviewedAt        DateTime?
  deletedAt         DateTime?

  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  submittedBy User      @relation("VoterChangeSubmitter", fields: [submittedByUserId], references: [id])
  reviewedBy  User?     @relation("VoterChangeReviewer", fields: [reviewedByUserId], references: [id])
  person      Person?   @relation(fields: [personId], references: [id])

  @@index([campaignId, status])
  @@index([personId])
  @@index([deletedAt])
  @@map("voter_change_requests")
}

// ─── ListImport ───────────────────────────────────────────────────────────────

model ListImport {
  id             String          @id @default(cuid())
  campaignId     String
  name           String
  type           ListImportType
  importedAt     DateTime        @default(now())
  importedById   String
  totalRows      Int
  matchedCount   Int             @default(0)
  newCount       Int             @default(0)
  reviewCount    Int             @default(0)

  campaign     Campaign              @relation(fields: [campaignId], references: [id])
  importedBy   User                  @relation("ListImportUser", fields: [importedById], references: [id])
  memberships  PersonListMembership[]

  @@index([campaignId])
  @@map("list_imports")
}

// ─── PersonListMembership ─────────────────────────────────────────────────────

model PersonListMembership {
  id            String                     @id @default(cuid())
  personId      String
  listImportId  String
  campaignId    String
  status        PersonListMembershipStatus
  reviewReason  String?
  createdAt     DateTime                   @default(now())

  person      Person     @relation(fields: [personId], references: [id])
  listImport  ListImport @relation(fields: [listImportId], references: [id])
  campaign    Campaign   @relation(fields: [campaignId], references: [id])

  @@unique([personId, listImportId])
  @@index([listImportId])
  @@index([campaignId])
  @@map("person_list_memberships")
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id            String      @id @default(cuid())
  campaignId    String
  name          String
  description   String?
  date          DateTime    // date only — time portions on startTime/endTime
  startTime     String      // "09:00"
  endTime       String?     // "12:00"
  location      String?
  eventType     EventType   @default(other)
  status        EventStatus @default(upcoming)
  canvassListId String?
  seriesId      String?     // null = standalone; shared value = recurring series occurrence
  createdById   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  campaign     Campaign      @relation(fields: [campaignId], references: [id])
  createdBy    User          @relation("EventCreator", fields: [createdById], references: [id])
  canvassList  CanvassList?  @relation(fields: [canvassListId], references: [id])
  attendees    EventAttendee[]

  @@index([campaignId])
  @@index([date])
  @@index([seriesId])
  @@index([deletedAt])
  @@map("events")
}

model EventAttendee {
  id          String              @id @default(cuid())
  eventId     String
  userId      String
  status      EventAttendeeStatus @default(confirmed)
  checkedInAt DateTime?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?

  event Event @relation(fields: [eventId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([userId])
  @@index([deletedAt])
  @@map("event_attendees")
}

// ─── Field Messages ───────────────────────────────────────────────────────────

model FieldMessage {
  id          String               @id @default(cuid())
  campaignId  String
  title       String
  content     String               @db.VarChar(500)
  priority    FieldMessagePriority @default(normal)
  createdById String
  expiresAt   DateTime?
  createdAt   DateTime             @default(now())
  deletedAt   DateTime?

  campaign  Campaign @relation(fields: [campaignId], references: [id])
  createdBy User     @relation("FieldMessageAuthor", fields: [createdById], references: [id])

  @@index([campaignId])
  @@index([deletedAt])
  @@map("field_messages")
}

// ─── Surveys ──────────────────────────────────────────────────────────────────

model Survey {
  id          String    @id @default(cuid())
  campaignId  String
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign   Campaign         @relation(fields: [campaignId], references: [id])
  createdBy  User             @relation("SurveyCreator", fields: [createdById], references: [id])
  questions  SurveyQuestion[]
  responses  SurveyResponse[]

  @@index([campaignId])
  @@index([deletedAt])
  @@map("surveys")
}

model SurveyQuestion {
  id           String             @id @default(cuid())
  surveyId     String
  label        String
  questionType SurveyQuestionType
  options      Json?
  sortOrder    Int                @default(0)
  required     Boolean            @default(false)
  createdAt    DateTime           @default(now())

  survey Survey @relation(fields: [surveyId], references: [id])

  @@index([surveyId])
  @@map("survey_questions")
}

model SurveyResponse {
  id                String    @id @default(cuid())
  surveyId          String
  personId          String
  canvassResponseId String?   @unique
  respondedById     String
  answers           Json
  respondedAt       DateTime  @default(now())
  createdAt         DateTime  @default(now())

  survey          Survey           @relation(fields: [surveyId], references: [id])
  person          Person           @relation(fields: [personId], references: [id])
  canvassResponse CanvassResponse? @relation(fields: [canvassResponseId], references: [id])
  respondedBy     User             @relation("SurveyResponder", fields: [respondedById], references: [id])

  @@index([surveyId])
  @@index([personId])
  @@map("survey_responses")
}

// ─── Signature Records ────────────────────────────────────────────────────────

model SignatureRecord {
  id            String   @id @default(cuid())
  personId      String
  campaignId    String
  purpose       String
  signatureData String   @db.Text
  collectedById String
  collectedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  person       Person             @relation(fields: [personId], references: [id])
  campaign     Campaign           @relation(fields: [campaignId], references: [id])
  collectedBy  User               @relation("SignatureCollector", fields: [collectedById], references: [id])
  consentItems SignatureConsent[]

  @@index([personId])
  @@index([campaignId])
  @@map("signature_records")
}

model SignatureConsentType {
  id         String    @id @default(cuid())
  campaignId String
  label      String
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  campaign Campaign          @relation(fields: [campaignId], references: [id])
  consents SignatureConsent[]

  @@index([campaignId])
  @@map("signature_consent_types")
}

model SignatureConsent {
  id            String   @id @default(cuid())
  signatureId   String
  consentTypeId String
  createdAt     DateTime @default(now())

  signature   SignatureRecord     @relation(fields: [signatureId], references: [id])
  consentType SignatureConsentType @relation(fields: [consentTypeId], references: [id])

  @@unique([signatureId, consentTypeId])
  @@index([signatureId])
  @@index([consentTypeId])
  @@map("signature_consents")
}

// ─── Support Access ───────────────────────────────────────────────────────────

model SupportAccessGrant {
  id          String    @id @default(cuid())
  campaignId  String
  requestedBy String
  requestedAt DateTime  @default(now())
  requestNote String?
  approvedBy  String?
  approvedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  revokedBy   String?
  deniedAt    DateTime?
  deniedBy    String?

  campaign        Campaign @relation(fields: [campaignId], references: [id])
  requestedByUser User     @relation("SupportAccessRequestedBy", fields: [requestedBy], references: [id])
  approvedByUser  User?    @relation("SupportAccessApprovedBy", fields: [approvedBy], references: [id])
  revokedByUser   User?    @relation("SupportAccessRevokedBy", fields: [revokedBy], references: [id])
  deniedByUser    User?    @relation("SupportAccessDeniedBy", fields: [deniedBy], references: [id])

  @@index([campaignId, expiresAt])
  @@map("support_access_grants")
}

// ─── Promo Codes ──────────────────────────────────────────────────────────────

model PromoCode {
  id                String    @id @default(cuid())
  code              String    @unique
  referrerName      String
  referrerEmail     String?
  discountPercent   Int       @default(5)
  stripeCouponId    String?
  isActive          Boolean   @default(true)
  maxUses           Int?
  usageCount        Int       @default(0)
  totalRevenue      Int       @default(0)
  totalDiscounts    Int       @default(0)
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  campaigns         Campaign[]

  @@map("promo_codes")
}

// ─── Data Supplier System ─────────────────────────────────────────────────────

model DataImport {
  id            String    @id @default(cuid())
  campaignId    String
  uploadedById  String
  fileName      String
  recordCount   Int
  validCount    Int
  errorCount    Int
  status        String    @default("pending")
  rawData       Json
  errors        Json?
  supplierNote  String?
  reviewNote    String?
  reviewedById  String?
  reviewedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campaign    Campaign @relation(fields: [campaignId], references: [id])
  uploadedBy  User     @relation("DataImportUploadedBy", fields: [uploadedById], references: [id])
  reviewedBy  User?    @relation("DataImportReviewedBy", fields: [reviewedById], references: [id])

  @@index([campaignId])
  @@index([uploadedById])
  @@map("data_imports")
}

model SupplierAcknowledgement {
  id              String   @id @default(cuid())
  campaignId      String
  signedById      String
  signedName      String
  signedEmail     String
  signatureData   String   @db.Text
  supplierEmail   String
  supplierCompany String?
  createdAt       DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])
  signedBy User     @relation("SupplierAcknowledgementSigner", fields: [signedById], references: [id])

  @@index([campaignId])
  @@map("supplier_acknowledgements")
}
